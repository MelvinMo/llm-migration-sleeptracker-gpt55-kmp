# This project reads the backend URL from Gradle properties at build time
# (see composeApp/build.gradle.kts), not from a .env file. This file is a
# reference for what to pass on the command line — copy it to .env for your
# own notes if useful, but the real mechanism is the -P flags shown below.
#
#   ./gradlew.bat :composeApp:assembleDebug -PapiUnencryptedUrl=http://your-lan-ip:7000/api
#
# Never commit real backend hostnames/IPs you consider private -- this file
# only holds placeholder values.

apiUnencryptedUrl=http://YOUR_LAN_IP:7000/api
apiEncryptedUrl=https://your-backend-host.example.com/api
